<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Do NOT add com.apple.security.app-sandbox here. A sandboxed app brokers
       NSOpenPanel through Powerbox, which returns nil and SIGABRTs the file
       picker in signed builds. Notarization needs the Hardened Runtime (the
       cs.* entitlements below), which is separate from the sandbox. It was
       added in 00460d8 by mistake and removed 2026-06-02. See
       docs/desktop-postmortem-macos-sandbox-filepicker-2026-06-02.md
       NOTE: keep this file pure ASCII with no double hyphen inside comments;
       Apple AMFIUnserializeXML (codesign) rejects both, unlike plutil. -->

  <!-- Network access for API and WebSocket connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Hardened Runtime: allow the WKWebView / WebKit JIT (required by Tauri) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (required by WebKit JIT) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- NOTE: APNs (aps-environment) is intentionally NOT declared here.
       This Entitlements.plist is applied to BOTH iOS and macOS desktop
       builds via bundle.macOS.entitlements in tauri.conf.json. The
       Forward Email LLC Developer ID Application certificate (used for
       macOS distribution) is not authorized for APNs, so embedding
       aps-environment caused the macOS launch-time entitlement check
       to fail with "CODESIGNING 1 Taskgated Invalid Signature" even
       though codesign + notarization succeeded at build time.

       For iOS, scripts/inject-ios-signing.cjs generates a separate
       ForwardEmail-iOS.entitlements file inside the generated Xcode project
       with the correct development or production aps-environment value.
       This shared file remains unchanged for macOS distribution. -->
</dict>
</plist>
