{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.0.0/crates/tauri-cli/capabilities-schema.json",
  "identifier": "default",
  "description": "Least-privilege capabilities for the Forward Email app. Only the permissions actually used by the frontend are granted.",
  "windows": ["main", "compose-*"],
  "permissions": [
    "core:default",

    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible",
    "core:webview:allow-create-webview-window",

    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",

    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "notification:allow-create-channel",
    "notification:allow-register-action-types",

    "deep-link:default",

    "process:allow-exit",
    "process:allow-restart",

    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    },

    "log:allow-log",
    "os:default",
    "core:menu:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "opener:allow-open-path"
  ],
  "platforms": ["linux", "macOS", "windows", "android", "iOS"]
}
